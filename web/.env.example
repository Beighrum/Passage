# Copy to .env.local for `vercel dev`. Mirror these in Vercel → Project → Settings → Environment Variables.

# --- Claude (required) ---
ANTHROPIC_API_KEY=
# Optional; default is claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Sessions (required) ---
PASSAGE_SESSION_SECRET=
PASSAGE_INTERNAL_PASSWORD=

# --- Optional: thread memory (Upstash Redis) ---
# Create a Redis database at https://upstash.com — REST URL + token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional: staff Google sign-in ---
# Same OAuth Web client ID in both (public + server)
# VITE_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_ID=
# Comma-separated email domains allowed for staff (e.g. passagetheatre.org)
# STAFF_GOOGLE_ALLOWED_DOMAINS=passagetheatre.org

# --- Optional: automation (n8n, Cowork, Vercel Cron) ---
# CRON_SECRET=

# --- Optional: Drive RAG (internal staff chat) — requires Upstash Redis above ---
# Share the target folder with the service account email (Viewer).
# Folder ID from the Drive URL: .../folders/FOLDER_ID
# DRIVE_RAG_FOLDER_ID=
# Base64-encoded service account JSON (GCP → IAM → service account → Keys → Add JSON):
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
