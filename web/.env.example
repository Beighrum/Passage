# Copy to .env.local for `vercel dev`. Mirror these in Vercel → Project → Settings → Environment Variables.

# --- Claude (required) ---
ANTHROPIC_API_KEY=
# Optional; default is claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Sessions (required) ---
PASSAGE_SESSION_SECRET=
PASSAGE_INTERNAL_PASSWORD=

# --- Optional: thread memory (Upstash Redis) ---
# Create a Redis database at https://upstash.com — REST URL + token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional: staff Google sign-in ---
# Same OAuth Web client ID in both (public + server)
# VITE_GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_ID=
# Comma-separated email domains allowed for staff (e.g. passagetheatre.org)
# STAFF_GOOGLE_ALLOWED_DOMAINS=passagetheatre.org

# --- Optional: automation (n8n, Cowork, Vercel Cron) ---
# CRON_SECRET=

# --- Optional: Drive RAG — requires Upstash Redis above ---
# Share each folder with the service account email (Viewer). Split keeps public assistant
# on audience-safe docs and staff assistant on grants / institutional files.
# Folder ID from the Drive URL: .../folders/FOLDER_ID
# DRIVE_RAG_FOLDER_ID_PUBLIC=
# DRIVE_RAG_FOLDER_ID_INTERNAL=
# Optional extra roots merged into the INTERNAL index (same service account must have access):
# DRIVE_RAG_FOLDER_ID_GRANTS=
# DRIVE_RAG_FOLDER_ID_ANNUAL_NEWSLETTER=
# Legacy: if no internal/grants/newsletter vars yield IDs, this single ID is used as INTERNAL.
# DRIVE_RAG_FOLDER_ID=
# Base64-encoded service account JSON (GCP → IAM → service account → Keys → Add JSON):
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=
# Optional tuning (Vercel Hobby ≈10s limit — keep defaults unless on Pro):
# DRIVE_RAG_MAX_FILES=25
# DRIVE_RAG_MAX_LIST_FILES=600
# Reindex: POST /api/jobs/run Authorization: Bearer $CRON_SECRET
# Body: {"job":"reindex-drive"} or {"job":"reindex-drive","scope":"public"|"internal"|"both"}
